#!/usr/bin/env python3
"""Claude Code shim wrapping the Bun-distributed package.

Runs ``claude`` from an isolated Bun install per version. Optionally applies a
small set of regex patches to the bundled ``cli.js`` (e.g. to enable expanded
thinking blocks with summarized API output on older versions). Patched installs
live in a sibling directory (``_patched_r<N>``) so the unpatched copy is always
reachable by re-running with ``--no-patch``.

Shim flags (consumed from the front of argv, in any order, before forwarding):
    --no-patch           Install to the unpatched dir and do not patch.
    --version X.Y.Z      Override the target Claude Code version.
    -v X.Y.Z             Same as --version.

Recovery: rm -rf ~/.claude-bun_* && claude

Pure stdlib on purpose: this script runs on every invocation, so we avoid
``uv run`` startup overhead.
"""

from __future__ import annotations

import os
import re
import shutil
import subprocess
import sys
from collections.abc import Callable
from dataclasses import dataclass
from pathlib import Path
from typing import override

DEFAULT_CLAUDE_VERSION = "2.1.112"
HOME = Path.home()
BUN_PATH = HOME / ".nix-profile" / "bin" / "bun"

# Versions that still need summarized-thinking injection via CLI flag. The flag
# was added in 2.1.94; below that, Claude Code has no --thinking-display flag.
THINKING_DISPLAY_FLAG_MIN = "2.1.94"

# 2.1.113 restructured the package: bin/claude is now a symlink to a native
# binary living in a platform-specific optional dep (e.g.
# @anthropic-ai/claude-code-<platform>/claude) rather than a bun-runnable JS
# script. For these versions the shim execs the binary directly.
NATIVE_BINARY_MIN = "2.1.113"


def version_tuple(v: str) -> tuple[int, ...]:
    return tuple(int(x) for x in v.split("."))


def uses_native_binary(version: str) -> bool:
    return version_tuple(version) >= version_tuple(NATIVE_BINARY_MIN)


# ---------------------------------------------------------------------------
# Patcher infrastructure


class PatchError(RuntimeError):
    pass


@dataclass(frozen=True)
class TextPatch:
    name: str
    pattern: re.Pattern[str]
    replacement: str


@dataclass(frozen=True)
class BinaryPatch:
    name: str
    pattern: re.Pattern[bytes]
    # Callable invoked by re.subn for each match; MUST return bytes of the same
    # width as ``match.group(0)`` so Mach-O / ELF offsets stay valid.
    replacement: Callable[[re.Match[bytes]], bytes]


@dataclass(frozen=True, kw_only=True)
class Patcher:
    # Bump ``revision`` whenever the patch set changes in a way that requires a
    # fresh install (new pattern, tweaked replacement, etc.). A new revision
    # means a new directory, so prior installs stay side-by-side as fallbacks.
    revision: int
    min_version: str | None = None  # inclusive; None = no lower bound
    max_version: str | None = None  # EXCLUSIVE; None = no upper bound

    def applies_to(self, version: str) -> bool:
        v = version_tuple(version)
        if self.min_version is not None and v < version_tuple(self.min_version):
            return False
        if self.max_version is not None and v >= version_tuple(self.max_version):
            return False
        return True

    def apply(self, install_dir: Path) -> None:
        raise NotImplementedError


@dataclass(frozen=True, kw_only=True)
class TextPatcher(Patcher):
    """Patches the bundled ``cli.js`` (pre-2.1.113 JS-script layout)."""

    patches: tuple[TextPatch, ...]
    # Regexes that MUST match after all patches have been applied. Guards
    # against a newer CLI whose structure made a pattern a silent no-op.
    verify: tuple[re.Pattern[str], ...]

    @override
    def apply(self, install_dir: Path) -> None:
        target = (
            install_dir
            / "install"
            / "global"
            / "node_modules"
            / "@anthropic-ai"
            / "claude-code"
            / "cli.js"
        )
        text = target.read_text()
        for patch in self.patches:
            new_text, count = patch.pattern.subn(patch.replacement, text)
            if count == 0:
                raise PatchError(f"patch {patch.name!r} did not match anything")
            text = new_text
        for marker in self.verify:
            if not marker.search(text):
                raise PatchError(f"post-apply verification failed: {marker.pattern!r}")
        target.write_text(text)


@dataclass(frozen=True, kw_only=True)
class BinaryPatcher(Patcher):
    """Patches the Bun-compiled native binary (2.1.113+ layout).

    Edits are length-preserving so Mach-O load commands / ELF section offsets
    stay valid. On macOS the binary is Developer ID-signed with hardened
    runtime; any byte change invalidates the signature and the kernel
    SIGKILLs on exec. We re-sign ad-hoc after patching. On Linux there is
    no codesigning equivalent (stock dynamically-linked ELF, no IMA xattrs,
    no signature section), so we skip that step.
    """

    patches: tuple[BinaryPatch, ...]
    verify: tuple[re.Pattern[bytes], ...]

    @override
    def apply(self, install_dir: Path) -> None:
        # bin/claude is a symlink into the platform-specific optional dep
        # (e.g. @anthropic-ai/claude-code-linux-x64/claude). Resolve so we
        # modify the actual binary, not the symlink.
        target = (install_dir / "bin" / "claude").resolve()
        data = target.read_bytes()
        for patch in self.patches:
            new_data, count = patch.pattern.subn(patch.replacement, data)
            if count == 0:
                raise PatchError(f"patch {patch.name!r} did not match anything")
            if len(new_data) != len(data):
                raise PatchError(
                    f"patch {patch.name!r} violated length preservation: "
                    f"{len(data)} -> {len(new_data)} bytes"
                )
            data = new_data
        for marker in self.verify:
            if not marker.search(data):
                raise PatchError(f"post-apply verification failed: {marker.pattern!r}")
        target.write_bytes(data)
        if sys.platform == "darwin":
            self._codesign(target)
        self._smoke_test(target)

    @staticmethod
    def _codesign(target: Path) -> None:
        # Absolute path: codesign ships in /usr/bin on every macOS install, and
        # pinning it avoids PATH-lookup footguns (and satisfies S607).
        result = subprocess.run(  # noqa: S603  # trusted absolute path
            ["/usr/bin/codesign", "--force", "--sign", "-", str(target)],
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            detail = (result.stderr or result.stdout).strip()
            raise PatchError(f"codesign failed: {detail}")

    @staticmethod
    def _smoke_test(target: Path) -> None:
        try:
            result = subprocess.run(  # noqa: S603  # trusted path
                [str(target), "--version"],
                capture_output=True,
                timeout=30,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            raise PatchError(f"patched binary failed smoke test: {exc}") from exc
        if result.returncode != 0:
            raise PatchError(f"patched binary exited {result.returncode} on --version")


# Text patcher (cli.js): enable expanded thinking blocks with summarized API
# output on Claude Code versions that pre-date the built-in behavior (< 2.1.113).
# Mirrors https://gist.github.com/phpmypython/148a942a34e19635770ec3383a865da8
# but applies against the Bun install path rather than ~/.claude/local.
TEXT_PATCHER_V1 = TextPatcher(
    revision=1,
    max_version="2.1.113",
    patches=(
        # 1. Drop the early-return guard that hides the thinking case when a
        #    couple of flags are unset:
        #       case"thinking":{if(!A&&!B)return null;  ->  case"thinking":{
        TextPatch(
            name="drop-thinking-early-return",
            pattern=re.compile(
                r'(case"thinking":\{)if\(![A-Za-z$_]+(?:&&![A-Za-z$_]+)+\)return null;'
            ),
            replacement=r"\1",
        ),
        # 2. Force isTranscriptMode true in the thinking block render so the
        #    block always expands:
        #       createElement(X,{...,isTranscriptMode:VAR,  ->  ...:true,
        TextPatch(
            name="force-transcript-mode",
            pattern=re.compile(
                r"(createElement\([A-Za-z0-9$_]+,\{addMargin:[A-Za-z$_]+,"
                r"param:[A-Za-z$_]+,isTranscriptMode:)[A-Za-z$_]+,"
            ),
            replacement=r"\1true,",
        ),
        # 3. Default the API-side thinking.display to "summarized" so 4.7+
        #    models actually return content (undefined is treated as omitted):
        #       .display??void 0:void 0  ->  .display??"summarized":void 0
        #    Only the ?? fallback changes; the ternary-false branch stays.
        TextPatch(
            name="default-display-summarized",
            pattern=re.compile(r"\.display\?\?void 0:void 0"),
            replacement='.display??"summarized":void 0',
        ),
    ),
    verify=(
        # The early-return pattern must no longer appear after case"thinking":{.
        re.compile(
            r'case"thinking":\{(?!if\(![A-Za-z$_]+(?:&&![A-Za-z$_]+)+\)return null;)'
        ),
        re.compile(r"isTranscriptMode:true,"),
        re.compile(r'\.display\?\?"summarized":void 0'),
    ),
)


# Binary patcher (bin/claude native binary, 2.1.113+). Length-preserving byte
# edits against the embedded minified JS — same trick as
# https://gist.github.com/phpmypython/a3c0267742fd65d2ebf247a5dd87ea88 but
# cross-platform (codesigning is darwin-only; Linux ELF has no analog). The
# API-side display default is handled by the --thinking-display summarized
# CLI flag we inject at exec time, so no third patch is needed here.
#
# The pattern appears TWICE in the binary (Bun's standalone-exe format embeds
# the module in two places). re.subn replaces globally, which is what we want.
BINARY_PATCHER_V1 = BinaryPatcher(
    revision=1,
    min_version="2.1.113",
    patches=(
        # 1. Neutralize the thinking-block early return by rewriting the first
        #    `!<var>` to `!1...1` (same width). `!11...1` evaluates to false
        #    (any number ≥1 is truthy, `!truthy` → false), short-circuiting
        #    the && chain so `return null` never fires. The && operands after
        #    the first are left alone — short-circuiting makes them irrelevant.
        BinaryPatch(
            name="neutralize-thinking-early-return",
            pattern=re.compile(rb'(case"thinking":\{if\()!([A-Za-z0-9_$]+)'),
            replacement=lambda m: m.group(1) + b"!" + b"1" * len(m.group(2)),
        ),
        # 2. Force thinking createElement to render expanded by flipping both
        #    isTranscriptMode and verbose to truthy `1`s (same width as the
        #    original identifiers). Only this createElement call is touched,
        #    so tool output etc. keeps its real verbose state.
        BinaryPatch(
            name="force-transcript-and-verbose",
            pattern=re.compile(
                rb"(createElement\([A-Za-z0-9_$]+,\{addMargin:[A-Za-z0-9_$]+,"
                rb"param:[A-Za-z0-9_$]+,isTranscriptMode:)([A-Za-z0-9_$]+)"
                rb"(,verbose:)([A-Za-z0-9_$]+)"
            ),
            replacement=lambda m: (
                m.group(1)
                + b"1" * len(m.group(2))
                + m.group(3)
                + b"1" * len(m.group(4))
            ),
        ),
    ),
    verify=(
        # Early-return neutralized: first operand is a run of `1`s.
        re.compile(rb'case"thinking":\{if\(!1+(?:&&![A-Za-z0-9_$]+)+\)return null;'),
        # isTranscriptMode + verbose both forced to runs of `1`s.
        re.compile(
            rb"createElement\([A-Za-z0-9_$]+,\{addMargin:[A-Za-z0-9_$]+,"
            rb"param:[A-Za-z0-9_$]+,isTranscriptMode:1+,verbose:1+"
        ),
    ),
)


PATCHERS: tuple[Patcher, ...] = (TEXT_PATCHER_V1, BINARY_PATCHER_V1)


def pick_patcher(version: str) -> Patcher | None:
    for p in PATCHERS:
        if p.applies_to(version):
            return p
    return None


# ---------------------------------------------------------------------------
# Shim argument parsing


@dataclass
class ShimArgs:
    version: str
    patch: bool
    forwarded: list[str]


def parse_shim_args(argv: list[str]) -> ShimArgs:
    version = DEFAULT_CLAUDE_VERSION
    patch = True
    args = list(argv)
    # Consume recognized shim flags from the front of argv, in any order,
    # until the first non-shim token. Bare --version / -v (no following
    # non-flag argument) is left in place so Claude Code prints its version.
    while args:
        a = args[0]
        if a in ("--version", "-v") and len(args) >= 2 and not args[1].startswith("-"):
            version = args[1]
            del args[:2]
        elif a == "--no-patch":
            patch = False
            del args[0]
        else:
            break
    return ShimArgs(version=version, patch=patch, forwarded=args)


# ---------------------------------------------------------------------------
# Bun install management


def install_dir(version: str, patcher: Patcher | None) -> Path:
    name = f".claude-bun_{version}"
    if patcher is not None:
        name += f"_patched_r{patcher.revision}"
    return HOME / name


def claude_bin(bun_install: Path) -> Path:
    return bun_install / "bin" / "claude"


def installed_version(bin_path: Path, version: str) -> str | None:
    """Query the installed Claude Code version, or None if unavailable.

    ``version`` selects the invocation style: pre-2.1.113 bin/claude is a
    bun-runnable JS script; 2.1.113+ is a native binary executed directly.
    """
    if uses_native_binary(version):
        argv = [str(bin_path), "--version"]
    else:
        argv = [str(BUN_PATH), str(bin_path), "--version"]
    try:
        result = subprocess.run(  # noqa: S603  # trusted constant paths
            argv,
            check=True,
            capture_output=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return None
    # Decode manually so a stray non-UTF-8 byte (e.g. when bun tries to parse
    # an ELF as JS and dumps the header) returns None instead of crashing.
    try:
        stdout = result.stdout.decode("utf-8")
    except UnicodeDecodeError:
        return None
    first_line = stdout.splitlines()[0] if stdout else ""
    return first_line.split(" ", 1)[0] or None


def bun_global_install(bun_install: Path, version: str) -> None:
    env = {**os.environ, "BUN_INSTALL": str(bun_install)}
    subprocess.run(  # noqa: S603  # trusted constant paths; version is a dotted literal
        [str(BUN_PATH), "install", "--global", f"@anthropic-ai/claude-code@{version}"],
        env=env,
        check=True,
    )


def ensure_installed(bun_install: Path, version: str, patcher: Patcher | None) -> None:
    bin_path = claude_bin(bun_install)
    if bin_path.is_file():
        current = installed_version(bin_path, version)
        if current == version:
            return
        print(f"Claude Code {current} -> {version}, reinstalling...", file=sys.stderr)
        shutil.rmtree(bun_install)
    else:
        print(f"Installing Claude Code {version}...", file=sys.stderr)

    try:
        bun_global_install(bun_install, version)
    except subprocess.CalledProcessError:
        # 2.1.113+ ships a postinstall hook (`node install.cjs`) that Bun
        # 1.3.x mis-parses (it trips over the platform-native binary as if it
        # were JS) and exits non-zero. But Bun wires bin/claude directly to
        # that native binary during resolve, so the install is still usable.
        # Accept it iff --version reports the target version.
        if not uses_native_binary(version):
            raise
        if installed_version(bin_path, version) != version:
            raise
        print(
            "bun install exited non-zero (known Bun 1.3.x + claude-code 2.1.113+ "
            "postinstall bug); binary is in place and reports the expected "
            "version, continuing.",
            file=sys.stderr,
        )

    if patcher is not None:
        kind = "binary" if isinstance(patcher, BinaryPatcher) else "cli.js"
        print(
            f"Applying patcher revision {patcher.revision} ({kind})...",
            file=sys.stderr,
        )
        try:
            patcher.apply(bun_install)
        except Exception:
            # Don't leave a _patched_r<N> directory that claims to be patched
            # but isn't — the promise of the name must hold.
            shutil.rmtree(bun_install, ignore_errors=True)
            raise


# ---------------------------------------------------------------------------
# Entrypoint


def main(argv: list[str]) -> int:
    shim = parse_shim_args(argv)

    if not BUN_PATH.is_file() or not os.access(BUN_PATH, os.X_OK):
        print(f"Error: Bun not found at {BUN_PATH}", file=sys.stderr)
        print("Run 'wlr-nix-rebuild' to install it", file=sys.stderr)
        return 1

    patcher = pick_patcher(shim.version) if shim.patch else None
    bun_install = install_dir(shim.version, patcher)

    try:
        ensure_installed(bun_install, shim.version, patcher)
    except PatchError as exc:
        print(f"Error: patch failed: {exc}", file=sys.stderr)
        print("Retry with --no-patch to skip patching.", file=sys.stderr)
        return 1
    except subprocess.CalledProcessError as exc:
        print(f"Error: bun install failed (exit {exc.returncode})", file=sys.stderr)
        return exc.returncode or 1

    forwarded = shim.forwarded
    # Older versions (pre-2.1.113) don't honor --thinking-display without the
    # patches above, but it's harmless on unpatched installs because the flag
    # was added in 2.1.94. Prepending lets users override with their own.
    if version_tuple(shim.version) >= version_tuple(THINKING_DISPLAY_FLAG_MIN):
        forwarded = ["--thinking-display", "summarized", *forwarded]

    env = {**os.environ, "BUN_INSTALL": str(bun_install)}
    bin_path = claude_bin(bun_install)
    if uses_native_binary(shim.version):
        # Native binary: exec directly, bypassing bun.
        os.execve(str(bin_path), [str(bin_path), *forwarded], env)  # noqa: S606
    else:
        os.execve(  # noqa: S606  # shell-less exec by design
            str(BUN_PATH),
            [str(BUN_PATH), str(bin_path), *forwarded],
            env,
        )


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

#!/usr/bin/env bash
set -euo pipefail

# Isolated Claude Code environment using Bun
# Recovery: rm -rf ~/.claude-bun_* && claude

CLAUDE_VERSION="2.1.112"

# Shim-level `--version X.Y.Z` (or `-v X.Y.Z`) selects a target version and is
# consumed here. Bare `--version` / `-v` (no following argument) falls through.
if { [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; } \
    && [ $# -ge 2 ] && [ "${2#-}" = "${2}" ]; then
    CLAUDE_VERSION="$2"
    shift 2
fi

# BUN_INSTALL controls where Bun puts global packages and binaries:
#   $BUN_INSTALL/install/global/node_modules/  - packages
#   $BUN_INSTALL/bin/                          - binaries
# Per-version install dirs keep old versions on disk across upgrades.
export BUN_INSTALL="$HOME/.claude-bun_$CLAUDE_VERSION"

CLAUDE_BIN="$BUN_INSTALL/bin/claude"

# Use Nix-provided Bun
BUN="$HOME/.nix-profile/bin/bun"

if ! [ -x "$BUN" ]; then
    echo "Error: Bun not found at $BUN" >&2
    echo "Run 'wlr-nix-rebuild' to install it" >&2
    exit 1
fi

# Bootstrap or upgrade if needed
if [ -x "$CLAUDE_BIN" ]; then
    INSTALLED_VERSION=$("$BUN" "$CLAUDE_BIN" --version 2>/dev/null | head -1 | sed 's/ .*//')
    if [ "$INSTALLED_VERSION" != "$CLAUDE_VERSION" ]; then
        echo "Claude Code $INSTALLED_VERSION -> $CLAUDE_VERSION, reinstalling..." >&2
        rm -rf "$BUN_INSTALL"
        "$BUN" install --global "@anthropic-ai/claude-code@$CLAUDE_VERSION"
    fi
else
    echo "Installing Claude Code $CLAUDE_VERSION..." >&2
    "$BUN" install --global "@anthropic-ai/claude-code@$CLAUDE_VERSION"
fi

# Inject --thinking-display summarized for versions >= 2.1.94 (when flag was added).
# Prepending lets user args override if they pass their own --thinking-display.
if [ "$(printf '%s\n' "2.1.94" "$CLAUDE_VERSION" | sort -V | head -1)" = "2.1.94" ]; then
    set -- --thinking-display summarized "$@"
fi

# Execute claude with Bun
exec "$BUN" "$CLAUDE_BIN" "$@"

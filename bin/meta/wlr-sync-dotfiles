#!/usr/bin/env bash
set -euo pipefail

# Private repo detection
PRIVATE_ENV_PATH="$HOME/.wlrenv-private"
HAS_PRIVATE=false
[[ -d "$PRIVATE_ENV_PATH" ]] && HAS_PRIVATE=true

print_diff() {
    if command -v delta >/dev/null 2>&1; then
        delta "$@" || true
    else
        diff "$@" || true
    fi
}

get_permissions() {
    if stat --version 2>/dev/null | grep -q GNU; then
        stat -c '%a' "$1" # GNU coreutils
    else
        stat -f '%A' "$1" # macOS, BSD
    fi
}

is_newer() {
    if stat --version 2>/dev/null | grep -q GNU; then
        # GNU coreutils
        mtime1="$(stat -c '%Y' "$1")"
        mtime2="$(stat -c '%Y' "$2")"
    else
        # macOS, BSD
        mtime1="$(stat -f '%m' "$1")"
        mtime2="$(stat -f '%m' "$2")"
    fi
    [ "$mtime1" -gt "$mtime2" ]
}

sync_dir() {
    local parent="${1%/*}"
    if [ "$parent" != "$1" ]; then
        sync_dir "$parent" || return 1
    fi
    if [ -d "$HOME/$1" ]; then
        if [ -L "$HOME/$1" ]; then
            target="$(realpath "$HOME/$1")"
            wlr-warn "update: $HOME/$1 is a directory symlink to $target"
            if wlr-ask "Replace with directory and copy contents of original target?"; then
                rm "$HOME/$1"
                cp -rp "$target" "$HOME/$1"
                return
            fi
            return 1
        fi
    elif [ -e "$HOME/$1" ]; then
        wlr-warn "update: $HOME/$1 exists, but is not a directory"
        return 1
    else
        mkdir -p "$HOME/$1"
    fi
}

render_file() {
    local path="$1"
    local base_file=""
    local source=""
    local uses_private=false
    local uname_val
    uname_val="$(uname)"

    # Step 1: Determine base file
    # Scope priority: host > uname > global; private shadows public within each scope.
    # Patches in patches/ still apply on top regardless of which scope the base came from.
    local scopes=()
    if [ -n "$HOSTNAME" ]; then
        scopes+=("host/$HOSTNAME/$path")
    fi
    if [ -n "$uname_val" ]; then
        scopes+=("uname/$uname_val/$path")
    fi
    scopes+=("$path")

    for rel in "${scopes[@]}"; do
        if $HAS_PRIVATE && [ -f "$PRIVATE_ENV_PATH/dotfiles/$rel" ]; then
            base_file="$PRIVATE_ENV_PATH/dotfiles/$rel"
            source="private"
            uses_private=true
            break
        elif [ -f "$WLR_ENV_PATH/dotfiles/$rel" ]; then
            base_file="$WLR_ENV_PATH/dotfiles/$rel"
            source="public"
            break
        fi
    done

    if [ -z "$base_file" ]; then
        return 1
    fi

    # Step 2: Collect patches (uname before host = general before specific)
    local patches=()

    if [ "$source" = "private" ]; then
        # Private source: only private patches apply
        if [ -n "$uname_val" ] && [ -f "$PRIVATE_ENV_PATH/patches/uname/$uname_val/$path.patch" ]; then
            patches+=("$PRIVATE_ENV_PATH/patches/uname/$uname_val/$path.patch")
            uses_private=true
        fi
        if [ -n "$HOSTNAME" ] && [ -f "$PRIVATE_ENV_PATH/patches/host/$HOSTNAME/$path.patch" ]; then
            patches+=("$PRIVATE_ENV_PATH/patches/host/$HOSTNAME/$path.patch")
            uses_private=true
        fi
    else
        # Public source: public patches, then private patches layer on top
        if [ -n "$uname_val" ] && [ -f "$WLR_ENV_PATH/patches/uname/$uname_val/$path.patch" ]; then
            patches+=("$WLR_ENV_PATH/patches/uname/$uname_val/$path.patch")
        fi
        if [ -n "$HOSTNAME" ] && [ -f "$WLR_ENV_PATH/patches/host/$HOSTNAME/$path.patch" ]; then
            patches+=("$WLR_ENV_PATH/patches/host/$HOSTNAME/$path.patch")
        fi
        if $HAS_PRIVATE; then
            if [ -n "$uname_val" ] && [ -f "$PRIVATE_ENV_PATH/patches/uname/$uname_val/$path.patch" ]; then
                patches+=("$PRIVATE_ENV_PATH/patches/uname/$uname_val/$path.patch")
                uses_private=true
            fi
            if [ -n "$HOSTNAME" ] && [ -f "$PRIVATE_ENV_PATH/patches/host/$HOSTNAME/$path.patch" ]; then
                patches+=("$PRIVATE_ENV_PATH/patches/host/$HOSTNAME/$path.patch")
                uses_private=true
            fi
        fi
    fi

    # Step 3: Determine rendered location
    local rendered_dir
    if $uses_private; then
        rendered_dir="$PRIVATE_ENV_PATH/rendered"
    else
        rendered_dir="$WLR_ENV_PATH/rendered"
    fi

    # If no patches, return the base file directly
    if [ ${#patches[@]} -eq 0 ]; then
        echo "$base_file"
        return 0
    fi

    # Check if re-rendering is needed
    local final="$rendered_dir/$path"
    local needs_patch=
    local current="$base_file"

    mkdir -p "$(dirname "$final")"
    for patch in "${patches[@]}"; do
        if ! [ -f "$final" ] || ! is_newer "$final" "$patch" || ! is_newer "$final" "$current"; then
            needs_patch=y
            break
        fi
    done

    if [ -n "$needs_patch" ]; then
        local tmp=""
        current="$base_file"
        for patchfile in "${patches[@]}"; do
            if [ -n "$tmp" ]; then
                rm "$tmp"
            fi
            tmp="$(mktemp)"
            if ! patch "$current" "$patchfile" -o "$tmp" >/dev/null 2>&1; then
                wlr-err "Failed to apply patch: $patchfile"
                wlr-err "  to file: $path (base: $base_file)"
                # Show what went wrong
                patch "$current" "$patchfile" -o /dev/null --verbose 2>&1 | head -20 || true
                [ -n "$tmp" ] && rm -f "$tmp"
                return 1
            fi
            current="$tmp"
        done
        mv "$current" "$final"
    fi

    echo "$final"
}

link_file() {
    local rendered_raw
    if ! rendered_raw="$(render_file "$1")"; then
        wlr-err "Skipping $1 due to patch failure"
        return 1
    fi
    local rendered
    rendered="$(realpath "$rendered_raw")"
    if [ -L "$HOME/$1" ]; then
        actual_target="$(realpath "$HOME/$1")"
        if [ "$rendered" != "$actual_target" ]; then
            print_diff "$HOME/$1" "$rendered"
            if wlr-ask "Update symlink $HOME/$1 to point to $rendered (currently $actual_target)?"; then
                ln -sf "$rendered" "$HOME/$1"
            fi
        fi
    elif [ -f "$HOME/$1" ]; then
        print_diff "$HOME/$1" "$rendered"
        if wlr-ask "Replace $HOME/$1 with a symlink to $rendered?"; then
            ln -sf "$rendered" "$HOME/$1"
        fi
    elif [ -e "$HOME/$1" ]; then
        wlr-warn "update: $HOME/$1 exists, but is not a regular file or symlink"
        return 1
    else
        ln -s "$rendered" "$HOME/$1"
    fi
}

# Discover all dotfile paths from both repos
declare -A seen_paths
dotfile_paths=()

UNAME_VAL="$(uname)"

# Scan a scope subdirectory of a dotfiles tree, stripping the scope prefix
# from discovered paths so they map to destinations under $HOME.
# Args: <repo-dotfiles-root> <scope-subdir-or-empty>
scan_scope() {
    local root="$1"
    local scope="$2"
    local search_dir
    if [ -z "$scope" ]; then
        search_dir="$root"
    else
        search_dir="$root/$scope"
    fi
    [ -d "$search_dir" ] || return 0
    while IFS= read -r filename; do
        local relative="${filename#"$search_dir/"}"
        # When scanning the global root, skip the scope subtrees so their
        # contents are only reached via the corresponding scope scan.
        if [ -z "$scope" ]; then
            case "$relative" in
                host/*|uname/*) continue ;;
            esac
        fi
        if [ -n "$relative" ] && [ "$relative" != "$filename" ] \
                && [ -z "${seen_paths[$relative]:-}" ]; then
            seen_paths["$relative"]=1
            dotfile_paths+=("$relative")
        fi
    done < <(find -L "$search_dir" -type f 2>/dev/null || true)
}

# Scan order doesn't affect base-file priority (render_file enforces that);
# it only determines the order of dotfile_paths. Use host > uname > global
# so more-specific scopes appear first in the processing queue.
repo_roots=("$WLR_ENV_PATH/dotfiles")
if $HAS_PRIVATE; then
    repo_roots+=("$PRIVATE_ENV_PATH/dotfiles")
fi
for repo_root in "${repo_roots[@]}"; do
    [ -d "$repo_root" ] || continue
    if [ -n "$HOSTNAME" ]; then
        scan_scope "$repo_root" "host/$HOSTNAME"
    fi
    if [ -n "$UNAME_VAL" ]; then
        scan_scope "$repo_root" "uname/$UNAME_VAL"
    fi
    scan_scope "$repo_root" ""
done

# Process each unique dotfile
failed_files=()
for relative in "${dotfile_paths[@]}"; do
    dir="${relative%/*}"
    if [ "$dir" != "$relative" ]; then
        sync_dir "$dir" || continue
    fi
    if ! link_file "$relative"; then
        failed_files+=("$relative")
    fi
done

# Report summary if there were failures
if [ ${#failed_files[@]} -gt 0 ]; then
    wlr-err ""
    wlr-err "Failed to sync ${#failed_files[@]} file(s):"
    for f in "${failed_files[@]}"; do
        wlr-err "  - $f"
    done
    exit 1
fi

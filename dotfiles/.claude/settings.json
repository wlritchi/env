{
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 99999,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "forgejo@wlr-cc-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": false,
    "opinionated-setup@wlr-cc-plugins": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-feedback@wlr-cc-plugins": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "3600000",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_AUTO_MIGRATE_TO_NATIVE": "1",
    "FORCE_AUTOUPDATE_PLUGINS": "1",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otel.wlritchi.com",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "extraKnownMarketplaces": {
    "wlr-cc-plugins": {
      "source": {
        "repo": "wlritchi/wlr-cc-plugins",
        "source": "github"
      }
    }
  },
  "model": "opus",
  "showThinkingSummaries": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  },
  "switchModelsOnFlag": false,
  "syntaxHighlightingDisabled": false,
  "theme": "custom:catppuccin-macchiato",
  "voiceEnabled": true
}
